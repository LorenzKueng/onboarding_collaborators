# Data files — synced by cloud storage, not Git
*.dta
*.csv
*.xlsx
*.xls
data/raw/
data/_derived/

# Output files — regenerated by code, not tracked
# No trailing slash so the pattern matches both a real directory and a symlink
output

# Scratch files
_scratch/

# Overleaf symlink — contents tracked by Overleaf, not Git
# No trailing slash so the pattern matches the symlink to the Overleaf folder
tex

# OS files
.DS_Store
Thumbs.db
